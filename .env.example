# ── Backend environment (copy to .env and fill in) ──────────────────────────

# MongoDB connection string — use a DEDICATED production user, not the dev one
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dbname?appName=App

# Long random secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port the API listens on
PORT=5000

# Allowed frontend origin(s) in production (comma-separated, https).
# Localhost is always allowed for development.
CORS_ORIGINS=https://app.mycompany.tn

# Legacy single-origin var (still read as a fallback for CORS)
CLIENT_URL=http://localhost:3000
